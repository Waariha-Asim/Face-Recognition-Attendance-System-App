<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/deep_navy">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Student Dashboard"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/soft_white"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/txtStudentInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Roll No"
        android:textSize="16sp"
        android:textColor="@color/cool_gray"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnStudentClassAI101"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI101"
        android:textColor="@color/soft_white"
        android:textStyle="bold"
        android:background="@drawable/bg_primary_button"
        android:layout_marginBottom="14dp" />

    <Button
        android:id="@+id/btnStudentClassSE102"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SE102"
        android:textColor="@color/soft_white"
        android:textStyle="bold"
        android:background="@drawable/bg_primary_button" />

</LinearLayout>